{
  "expo": {
    "name": "Lurdinha",
    "slug": "lurdinha-app",
    "scheme": "lurdinhaapp",
    "version": "1.0.15",
    "orientation": "portrait",
    "icon": "./assets/app-store-icon-1024.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lurdinha.app",
      "buildNumber": "16",
      "icon": "./assets/app-store-icon-1024.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos acessar sua câmera para você tirar fotos de perfil.",
        "NSPhotoLibraryUsageDescription": "Precisamos acessar suas fotos para você escolher uma foto de perfil.",
        "NSPhotoLibraryAddUsageDescription": "Precisamos salvar fotos de perfil na sua biblioteca de fotos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.lurdinha.app",
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "279141d4-e633-4c9d-adfc-39f8733c4798"
      }
    }
  }
}
